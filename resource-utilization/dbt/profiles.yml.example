# profiles.yml.example
# Safe template — copy this to profiles.yml and fill in your details.
# This file IS committed to GitHub. profiles.yml is NOT.
#
# Steps:
#   1. cp dbt/profiles.yml.example dbt/profiles.yml
#   2. Replace YOUR_NAME with your first name (lowercase, no spaces)
#   3. Replace YOUR_PASSWORD_HERE with the password from .env

resource_utilization:

  # Default target when you run dbt locally — always your personal schema
  target: personal

  outputs:

    # ── PERSONAL ─────────────────────────────────────────────────────
    # Your private development schemas. Only you write here.
    # Run: dbt run --target personal (or just: dbt run)
    personal:
      type: postgres
      host: postgres             # dbt runs inside Docker — use container name
      port: 5432
      user: mds_user
      password: YOUR_PASSWORD_HERE   # copy from .env
      dbname: btg_resource_utilization
      schema: dbt_YOUR_NAME          # e.g. dbt_alice, dbt_john
      threads: 4

    # ── CI ───────────────────────────────────────────────────────────
    # Used by GitHub Actions on Pull Requests. Runs automatically.
    # You never run this manually.
    ci:
      type: postgres
      host: postgres             # dbt runs inside Docker — use container name
      port: 5432
      user: mds_user
      password: YOUR_PASSWORD_HERE   # copy from .env
      dbname: btg_resource_utilization
      schema: ci
      threads: 4

    # ── DEV ──────────────────────────────────────────────────────────
    # Shared team schemas. Run manually after merge to verify full project.
    # Run: dbt build --target dev
    dev:
      type: postgres
      host: postgres             # dbt runs inside Docker — use container name
      port: 5432
      user: mds_user
      password: YOUR_PASSWORD_HERE   # copy from .env
      dbname: btg_resource_utilization
      schema: dev
      threads: 4

    # ── PRODUCTION ───────────────────────────────────────────────────
    # Airflow writes here on a schedule. Metabase reads from here.
    # You never run dbt --target prod manually.
    prod:
      type: postgres
      host: postgres             # dbt runs inside Docker — use container name
      port: 5432
      user: mds_user
      password: YOUR_PASSWORD_HERE   # copy from .env
      dbname: btg_resource_utilization
      schema: prod
      threads: 4
